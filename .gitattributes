# ============================================================================
# FamGo Project .gitattributes
# Enforce consistent line endings and file handling across platforms
# ============================================================================

# Default: normalize text files to LF
* text=auto eol=lf

# Go source files
*.go text eol=lf

# Node/React (TypeScript, JavaScript, JSX/TSX)
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf

# Config and infrastructure files
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.env  text eol=lf
Dockerfile text eol=lf

# Documentation
*.md   text eol=lf
*.txt  text eol=lf
*.gitignore text eol=lf

# Shell and scripts
*.sh   text eol=lf
*.ps1  text eol=lf

# HTML/CSS
*.html text eol=lf
*.css  text eol=lf

# Binary files (no conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.exe  binary
*.dll  binary

# ============================================================================
# Notes:
# - LF enforced for all text/code files.
# - Binary files are excluded from line ending conversion.
# - This prevents Git warnings about LF/CRLF differences on Windows.
# ============================================================================
