<?xml version="1.0"?>
<clickhouse>
    <!-- ================================================================ -->
    <!-- LOGGING CONFIGURATION -->
    <!-- ================================================================ -->
    <logger>
        <level>notice</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>1000M</size>
        <count>10</count>
    </logger>

    <!-- ================================================================ -->
    <!-- SERVER CONFIGURATION -->
    <!-- ================================================================ -->
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <interserver_http_port>9009</interserver_http_port>

    <!-- Listen on all interfaces -->
    <listen_host>::</listen_host>

    <!-- ================================================================ -->
    <!-- DATABASE CONFIGURATION -->
    <!-- ================================================================ -->
    <path>/var/lib/clickhouse/</path>
    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>
    <user_files_path>/var/lib/clickhouse/user_files/</user_files_path>

    <!-- ================================================================ -->
    <!-- USER & AUTHENTICATION -->
    <!-- ================================================================ -->
    <users_config>users.xml</users_config>

    <!-- ================================================================ -->
    <!-- DEFAULT USER PROFILE -->
    <!-- ================================================================ -->
    <default_profile>default</default_profile>

    <!-- ================================================================ -->
    <!-- MEMORY SETTINGS -->
    <!-- ================================================================ -->
    <!-- Set reasonable memory limits for development -->
    <max_memory_usage>4000000000</max_memory_usage>
    <max_memory_usage_for_user>3000000000</max_memory_usage_for_user>

    <!-- ================================================================ -->
    <!-- QUERY LIMITS -->
    <!-- ================================================================ -->
    <max_connections>4096</max_connections>
    <keep_alive_timeout>3</keep_alive_timeout>

    <!-- ================================================================ -->
    <!-- NETWORK SETTINGS -->
    <!-- ================================================================ -->
    <allow_empty_result_for_aggregation_by_empty_set>false</allow_empty_result_for_aggregation_by_empty_set>

    <!-- ================================================================ -->
    <!-- COMPRESSION SETTINGS -->
    <!-- ================================================================ -->
    <compression>
        <case>
            <min_part_size>10000000000</min_part_size>
            <min_part_size_ratio>0.01</min_part_size_ratio>
            <method>lz4</method>
        </case>
    </compression>

    <!-- ================================================================ -->
    <!-- DISTRIBUTED QUERY EXECUTION -->
    <!-- ================================================================ -->
    <remote_servers>
        <famgo_cluster>
            <shard>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </famgo_cluster>
    </remote_servers>

    <!-- ================================================================ -->
    <!-- REPLICATION & BACKUP -->
    <!-- ================================================================ -->
    <zookeeper>
        <!-- Uncomment for HA setup with ZooKeeper -->
        <!-- <node>
            <host>zookeeper</host>
            <port>2181</port>
        </node> -->
    </zookeeper>

    <!-- ================================================================ -->
    <!-- METRICS & MONITORING -->
    <!-- ================================================================ -->
    <!-- Enable built-in Prometheus metrics -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>8123</port>
    </prometheus>

    <!-- ================================================================ -->
    <!-- QUERY CACHE -->
    <!-- ================================================================ -->
    <query_cache>
        <max_size_in_bytes>1073741824</max_size_in_bytes>
        <max_entries>1024</max_entries>
    </query_cache>

    <!-- ================================================================ -->
    <!-- SECURITY & TLS -->
    <!-- ================================================================ -->
    <!-- Uncomment for TLS -->
    <!-- <https_port>8443</https_port>
    <openSSL>
        <server>
            <certificateFile>/etc/clickhouse-server/server.crt</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/server.key</privateKeyFile>
        </server>
    </openSSL> -->

    <!-- ================================================================ -->
    <!-- BACKGROUND MERGES & MUTATIONS -->
    <!-- ================================================================ -->
    <background_pool_size>16</background_pool_size>
    <background_schedule_pool_size>128</background_schedule_pool_size>

    <!-- ================================================================ -->
    <!-- STORAGE & TABLE SETTINGS -->
    <!-- ================================================================ -->
    <uncompressed_cache_size>8589934592</uncompressed_cache_size>
    <mark_cache_size>5368709120</mark_cache_size>

</clickhouse>
