# services/ride-service/.env.example
# Ride Service Configuration

SERVICE_NAME=ride-service
ENV=development
LOG_LEVEL=debug
GRPC_PORT=5003

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=famgo_platform
DB_SSL_MODE=disable

# Redis
REDIS_URL=redis://redis:6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=ride-service

# Ride Configuration
RIDE_REQUEST_TIMEOUT=60s
RIDE_MINIMUM_FARE=50
RIDE_COMMISSION_PERCENTAGE=20
RIDE_CANCELLATION_FEE_PERCENTAGE=25

# Observability
JAEGER_URL=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Service Dependencies
AUTH_SERVICE_URL=auth-service:5001
GPS_SERVICE_URL=gps-service:5002
