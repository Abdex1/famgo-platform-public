# services/gps-service/.env.example
# GPS Service Configuration

SERVICE_NAME=gps-service
ENV=development
LOG_LEVEL=debug
GRPC_PORT=5002

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=famgo_platform
DB_SSL_MODE=disable

# Redis (for GEO indices)
REDIS_URL=redis://redis:6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=gps-service

# GPS Configuration
LOCATION_UPDATE_FREQUENCY=5s
NEARBY_DRIVER_RADIUS_KM=5
MAX_DRIVERS_IN_RADIUS=20
REDIS_GEO_KEY_PREFIX=driver:location

# Observability
JAEGER_URL=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Auth
AUTH_SERVICE_URL=auth-service:5001
