# services/dispatch-service/.env.example
# Dispatch Service Configuration

SERVICE_NAME=dispatch-service
ENV=development
LOG_LEVEL=debug
GRPC_PORT=5004

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=famgo_platform
DB_SSL_MODE=disable

# Redis
REDIS_URL=redis://redis:6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=dispatch-service

# Dispatch Configuration
DRIVER_ACCEPTANCE_TIMEOUT=30s
DRIVER_REQUEST_RETRY_COUNT=3
NEARBY_DRIVER_RADIUS_KM=5
MAX_DRIVERS_TO_REQUEST=5
ETA_CALCULATION_METHOD=google_maps

# Google Maps API
GOOGLE_MAPS_API_KEY=your_api_key

# Matching Algorithm
MATCHING_STRATEGY=best_match
DRIVER_SCORE_WEIGHTS_DISTANCE=0.4
DRIVER_SCORE_WEIGHTS_RATING=0.3
DRIVER_SCORE_WEIGHTS_ACCEPTANCE_RATE=0.2
DRIVER_SCORE_WEIGHTS_AVAILABILITY=0.1

# Observability
JAEGER_URL=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Service Dependencies
AUTH_SERVICE_URL=auth-service:5001
GPS_SERVICE_URL=gps-service:5002
RIDE_SERVICE_URL=ride-service:5003
