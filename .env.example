# ============================================================================
# FamGo Platform Environment Configuration
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in the values for your environment
# 3. Never commit .env.local to git
# 4. Update this file if new variables are added
#
# SECURITY NOTICE:
# - Never commit actual secrets to version control
# - Use .env.local for local development only
# - Use environment variables or Vault for production
# - Rotate secrets regularly
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL with PostGIS extension
DB_PASSWORD=change_me_to_strong_password
DB_USER=famgo
DB_NAME=famgo
DB_HOST=postgres
DB_PORT=5432
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_SSL_MODE=disable

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# MinIO S3-compatible storage or AWS S3
MINIO_USER=minio
MINIO_PASSWORD=change_me_to_strong_password
MINIO_URL=http://minio:9000
MINIO_CONSOLE_URL=http://minio:9001
MINIO_BUCKET_NAME=famgo

# AWS S3 (if not using MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================================
# CACHE & SESSION CONFIGURATION
# ============================================================================
# Redis for caching and sessions
REDIS_PASSWORD=change_me_to_strong_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600
SESSION_TIMEOUT=3600

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_to_strong_password

# ClickHouse (Analytics)
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=change_me_to_strong_password
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# Jaeger (Tracing)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Sentry (Error Tracking)
SENTRY_DSN=

# ============================================================================
# MESSAGING & EVENTS
# ============================================================================
# Apache Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_PREFIX=famgo
KAFKA_CONSUMER_GROUP=famgo

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Configuration
JWT_SECRET=change_me_to_very_long_random_string
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Bcrypt Configuration
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY=10m
OTP_MAX_ATTEMPTS=3

# OAuth2 Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=debug
DEBUG_MODE=false
PORT=3000

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_BASE_URL=http://localhost:3000
API_VERSION=v1
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# PAYMENT CONFIGURATION
# ============================================================================
# Ethiopian Payment Providers
TELEBIRR_API_KEY=
TELEBIRR_MERCHANT_ID=
TELEBIRR_ENVIRONMENT=sandbox

CBE_BIRR_API_KEY=
CBE_BIRR_MERCHANT_ID=
CBE_BIRR_ENVIRONMENT=sandbox

CHAPA_API_KEY=
CHAPA_ENVIRONMENT=test

# Wallet Configuration
WALLET_MIN_BALANCE=0
WALLET_MAX_BALANCE=999999999
TRANSACTION_FEE_PERCENTAGE=2.5

# ============================================================================
# COMMUNICATION CONFIGURATION
# ============================================================================
# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@famgo.com
SMTP_USE_TLS=true

# SMS Provider
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=+251

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================================================
# GEOLOCATION & MAPS
# ============================================================================
# Google Maps
GOOGLE_MAPS_API_KEY=

# OpenStreetMap (OSRM for routing)
OSRM_API_URL=http://router.project-osrm.org

# PostGIS Configuration
POSTGIS_EXTENSION=true

# ============================================================================
# MACHINE LEARNING & AI
# ============================================================================
# ML Service Endpoint
ML_API_ENDPOINT=http://ml-service:8000
ML_API_KEY=

# OpenAI (GPT for assistance)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_POOLING_ENABLED=true
FEATURE_SUBSCRIPTION_ENABLED=true
FEATURE_VOICE_BOOKING_ENABLED=true
FEATURE_WALLET_ENABLED=true
FEATURE_SAFETY_ENABLED=true
FEATURE_FRAUD_DETECTION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true

# ============================================================================
# GEOLOCATION SETTINGS
# ============================================================================
GEOLOCATION_CACHE_TTL=300
MAX_LOCATION_HISTORY=1000
NEARBY_DRIVER_RADIUS_KM=5
MATCH_TIMEOUT_SECONDS=30

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3://backups/

# ============================================================================
# DEVELOPMENT & TESTING ONLY
# ============================================================================
# Mock Services (for testing without real services)
MOCK_SMS=false
MOCK_EMAIL=false
MOCK_PAYMENT=false
MOCK_GEOLOCATION=false

# Test Data
TEST_USER_EMAIL=test@famgo.local
TEST_USER_PASSWORD=TestPassword123!

# ============================================================================
# KUBERNETES & CONTAINER ORCHESTRATION
# ============================================================================
# Pod Configuration
KUBERNETES_NAMESPACE=production
KUBERNETES_REPLICA_COUNT=3

# ============================================================================
# NOTES
# ============================================================================
# - All variables with empty values must be filled for production
# - Passwords must be strong (min 16 characters, mixed case, numbers, special chars)
# - API keys should be rotated regularly
# - Use AWS Secrets Manager or HashiCorp Vault in production
# - Review security settings for staging and production deployments
# ============================================================================
